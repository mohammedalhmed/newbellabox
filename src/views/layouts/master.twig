<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ lang == 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    
    {# SEO Meta Tags #}
    <title>{% block title %}{{ store.name }}{% endblock %}</title>
    <meta name="description" content="{% block description %}{{ store.description }}{% endblock %}">
    <meta name="keywords" content="{% block keywords %}تجميل، عناية بالبشرة، مستحضرات{% endblock %}">
    <meta name="author" content="{{ store.name }}">
    
    {# Open Graph Tags #}
    <meta property="og:title" content="{% block og_title %}{{ store.name }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ store.description }}{% endblock %}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ store.url }}">
    <meta property="og:image" content="{% block og_image %}{{ store.logo }}{% endblock %}">
    
    {# Favicon #}
    <link rel="icon" type="image/x-icon" href="{{ store.favicon }}">
    
    {# Stylesheets #}
    <link rel="stylesheet" href="{{ 'assets/styles/main.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'assets/styles/header.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'assets/styles/products.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'assets/styles/footer.css' | asset_url }}">
    
    {# Font Awesome Icons #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    {# Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    {# Additional Styles Block #}
    {% block extra_styles %}{% endblock %}
</head>
<body>
    {# Header Component #}
    {% include 'components/header/header.twig' %}
    
    {# Main Content #}
    <main class="main-content">
        {% block content %}{% endblock %}
    </main>
    
    {# Footer Component #}
    {% include 'components/footer/footer.twig' %}
    
    {# Back to Top Button #}
    <button class="back-to-top" aria-label="{{ 'common.back_to_top' | trans }}">
        <i class="fas fa-arrow-up"></i>
    </button>
    
    {# Scripts #}
    <script src="{{ 'assets/js/main.js' | asset_url }}"></script>
    
    {# Additional Scripts Block #}
    {% block extra_scripts %}{% endblock %}
    
    {# Analytics and Tracking #}
    {% if store.google_analytics_id %}
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ store.google_analytics_id }}"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '{{ store.google_analytics_id }}');
        </script>
    {% endif %}
</body>
</html>
